# ─── Frontend Environment Variables ────────────────────────────────────────
# Copy to .env.local for local dev. Never commit .env.local to git.

# ── Required ────────────────────────────────────────────────────────────────
# Backend API URL (Render deployment URL)
NEXT_PUBLIC_API_URL=https://skillbridge-backend.onrender.com

# ── Dev Mode (remove in production with real Clerk auth) ────────────────────
# Sets X-Dev-Role header on all API requests to bypass JWT auth
# Options: STUDENT | TRAINER | INSTITUTION | PROGRAMME_MANAGER | MONITORING_OFFICER
NEXT_PUBLIC_DEV_ROLE=STUDENT

# ── Production Clerk Auth (add when Clerk is configured) ────────────────────
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
# CLERK_SECRET_KEY=sk_live_...
