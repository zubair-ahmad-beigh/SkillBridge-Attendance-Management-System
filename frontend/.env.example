# ─── Frontend Environment Variables ────────────────────────────────────────
# Copy this file to .env.local and fill in actual values.
# Never commit .env.local to git.

# Backend API URL
NEXT_PUBLIC_API_URL=https://<your-render-backend-url>

# Dev Mode: set a role to bypass auth in development
# Remove or leave empty in production
NEXT_PUBLIC_DEV_ROLE=STUDENT

# Clerk Auth (required for production, optional if using NEXT_PUBLIC_DEV_ROLE)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard/route
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding
