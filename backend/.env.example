# ─── Backend Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in actual values. Never commit .env to git.

# Server
PORT=8080

# MySQL Database
DATABASE_URL=jdbc:mysql://<host>:3306/<dbname>?useSSL=true&serverTimezone=UTC
DB_USERNAME=<your_db_username>
DB_PASSWORD=<your_db_password>

# Clerk Authentication (get from clerk.com dashboard)
CLERK_ISSUER_URI=https://<your-clerk-frontend-api>.clerk.accounts.dev

# Frontend URL (for CORS)
FRONTEND_URL=https://<your-frontend-domain>

# Spring profile: use 'dev' for local dev without Clerk, leave empty for production
SPRING_PROFILES_ACTIVE=dev
